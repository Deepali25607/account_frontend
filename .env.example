# Web dev uses the Vite proxy, so this can stay blank.
# For the Android app (and any non-localhost build), point this at your
# deployed backend, e.g. https://api.yourcompany.com
VITE_API_URL=

# Base URL used to build customer-facing "share invoice" links (WhatsApp).
# On the web this defaults to the current origin and can stay blank. The Android
# app's origin is https://localhost, which customers can't open — so the app
# build MUST set this to the deployed web app URL, e.g. https://app.yourcompany.com
VITE_PUBLIC_WEB_URL=
